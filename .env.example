# ── E-Commerce Pricing Intelligence Agent — Environment Configuration ──────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ── Required ───────────────────────────────────────────────────────────────────
# Google Gemini API key — obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Optional — LLM Tuning ────────────────────────────────────────────────────
# Gemini model variant. Options: gemini-1.5-flash, gemini-1.5-pro, gemini-1.0-pro
GEMINI_MODEL=gemini-1.5-flash

# Generation temperature (0.0 = deterministic, 1.0 = creative)
LLM_TEMPERATURE=0.3

# Maximum tokens in LLM response
LLM_MAX_TOKENS=512

# ── Optional — Data ────────────────────────────────────────────────────────────
# Absolute or relative path to the retail dataset CSV
DATA_FILE=data.csv
